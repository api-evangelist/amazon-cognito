    },
    "TagKeys": {
      "allOf": [
        {
          "$ref": "#/components/schemas/UserPoolTagsListType"
        },
        {
          "description": "The keys of the tags to remove from the user pool."
        }
      ]
    }
  },
  "required": [
    "ResourceArn",
    "TagKeys"
  ]
}