      "@id": "aws:ReplyToEmailAddress",
      "@type": "xsd:string"
    },
    "EmailSendingAccount": {
      "@id": "aws:EmailSendingAccount",
      "@type": "xsd:string"
    },
    "SmsConfiguration": {
      "@id": "aws:SmsConfiguration",
      "@type": "@id"
    },
    "SnsCallerArn": {
      "@id": "aws:SnsCallerArn",
      "@type": "xsd:string"
    },
    "ExternalId": {
      "@id": "aws:ExternalId",
